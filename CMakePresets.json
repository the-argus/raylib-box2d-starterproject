{
  "version": 5,

  "configurePresets": [
    {
      "name": "dev-base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build-${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "dev",
      "generator": "Ninja",
      "displayName": "Developer build",
      "inherits": ["dev-base"]
    },
    {
      "name": "vs-dev",
      "generator": "Visual Studio 17 2022",
      "displayName": "Visual Studio developer build",
      "inherits": ["dev-base"]
    },
    {
      "name": "vs-dev-noreload",
      "generator": "Visual Studio 17 2022",
      "displayName": "Visual Studio developer build without hot reload",
      "inherits": ["dev-base"],
      "cacheVariables": {
        "GAME_NO_HOTRELOAD": "ON"
      }
    },
    {
      "name": "release",
      "binaryDir": "${sourceDir}/build-${presetName}",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "dev-noreload",
      "inherits": ["dev-base"],
      "generator": "Ninja",
      "cacheVariables": {
        "GAME_NO_HOTRELOAD": "ON"
      }
    }
  ]
}
